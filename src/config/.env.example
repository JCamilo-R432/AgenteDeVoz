# =============================================================
# CONFIGURACIÓN DEL AGENTE DE VOZ
# Copiar este archivo como .env y completar los valores reales
# NUNCA commitear el archivo .env al repositorio
# =============================================================

# ---- Voice Configuration ----
STT_ENGINE=google
TTS_ENGINE=pyttsx3
LANGUAGE=es-CO

# ---- LLM / AI ----
# Usar OpenAI o Anthropic (al menos uno requerido)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ---- Google Cloud ----
# Ruta al archivo JSON de credenciales de Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/google-cloud.json

# ---- Twilio ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+16015551234
TWILIO_WEBHOOK_URL=https://api.agentevoz.com/api/v1/voice/webhook

# ---- Base de Datos ----
DATABASE_URL=postgresql://user:password@localhost:5432/agentevoz

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=1800

# ---- Reglas de Negocio ----
MAX_CALL_DURATION=1800
ESCALATION_NUMBER=+573001234567
MAX_FALLBACK_ATTEMPTS=3
SILENCE_TIMEOUT_SECONDS=5

# ---- Seguridad (CAMBIAR EN PRODUCCIÓN) ----
JWT_SECRET_KEY=your-super-secret-key-minimum-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ---- Logging ----
LOG_LEVEL=INFO
RECORD_CALLS=false

# ---- CRM (Salesforce / HubSpot) ----
CRM_BASE_URL=https://api.hubapi.com
CRM_API_KEY=your-crm-api-key

# ---- Email (SendGrid) ----
SENDGRID_API_KEY=SG.your-sendgrid-key
EMAIL_FROM=noreply@agentevoz.com
EMAIL_FROM_NAME=Agente de Voz - Soporte

# ---- Entorno ----
ENV=development
