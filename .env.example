# ============================================================
# AgenteDeVoz — Environment Variables Example
# Copy to .env and fill in your values
# ============================================================

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (development — zero setup required)
DATABASE_URL=sqlite+aiosqlite:///./orders_dev.db

# PostgreSQL (production)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/econify_orders

# ── JWT ────────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── API Server ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8001

# ── SQLAlchemy debug (optional) ────────────────────────────────────────────────
SQL_ECHO=false

# ── Notifications (optional — stub works without these) ───────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=notifications@econify.store
SMTP_PASSWORD=

# ── Shipping APIs (optional — stub works without these) ───────────────────────
COORDINADORA_API_KEY=
SERVIENTREGA_API_KEY=

# ── Voice / AI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa

# ── Twilio ─────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_URL=
